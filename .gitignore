# ==================================================
# SATICA V2.0 — .gitignore
# Archivos excluidos del repositorio GitHub
# ==================================================

# --- Datos sensibles y privados ---
# Llaves y credenciales
*.json
ee_credentials*.R
*_key.json
*_credentials*

# --- Datos locales pesados (no son código) ---
*.RData
*.Rhistory
-PAL21002.Rhistory
*.rds
*.RDS

# --- Datos de salida y reportes generados ---
reporte.html
*.docx
*.pptx
*.xlsx
*.pdf

# --- Carpetas con datos geográficos y de salida ---
capas/*
!capas/Caña_SOR_OK.*
!capas/Corregimientos.*
!capas/restricciones/
data_estatica/*
!data_estatica/GEO_CACHE_SATICA.rds
!data_estatica/REST_CACHE_SATICA.RData
data_master/
modelo_rds/*
!modelo_rds/xgb_model_V9_regresion_geoespacial.ubj
!modelo_rds/v9_features_geoespacial.rds
reportes/
reportes_alerta/
reportes_cosecha/
reportes_finales/
resultados_diagnostico/
resultados_modelo/
actas/
.archivos_temporales/

# --- Archivos temporales de R ---
*.Rout
.Rapp.history

# --- Archivos de Sistema ---
.DS_Store
Thumbs.db
